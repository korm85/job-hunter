{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/superpowers-gate.sh",
            "timeout": 8,
            "statusMessage": "Checking superpowers gate..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/global-session-start.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/global-session-start.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/global-session-start.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/korm85/.nvm/versions/node/v22.22.3/bin/node\" \"/home/korm85/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/korm85/.nvm/versions/node/v22.22.3/bin/node\" \"/home/korm85/.claude/hooks/caveman-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/korm85/.nvm/versions/node/v22.22.3/bin/node\" \"/home/korm85/.claude/hooks/context-guard.js\"",
            "timeout": 5,
            "statusMessage": "Checking context..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"/home/korm85/.claude/hooks/caveman-statusline.sh\""
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "caveman@caveman": true,
    "slack@claude-plugins-official": true,
    "push-to-git@user": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "user": {
      "path": "/home/korm85/.claude/plugins/marketplaces/user"
    }
  },
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.167",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}